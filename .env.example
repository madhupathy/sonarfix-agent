# LLM Settings
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# SonarQube
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=your-token-here
SONARQUBE_USERNAME=your_username
SONARQUBE_PASSWORD=your_password

# Security
# Set to false only if using self-signed certificates (not recommended for production)
SSL_VERIFY=true

# Workspace
# Directory where repositories are cloned during fix jobs
# Defaults to ~/.sonarfix/workspaces (cross-platform)
WORKSPACE_DIR=~/.sonarfix/workspaces

# Git (optional, for auto-push)
GIT_PUSH_REMOTE=origin
