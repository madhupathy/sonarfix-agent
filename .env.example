# SonarQube connection
SONARQUBE_URL=https://sonarqube.example.com
SONARQUBE_USERNAME=your_username
SONARQUBE_PASSWORD=your_password

# LLM-based fixer (preferred — directly fixes code via LLM API)
LLM_API_KEY=dummy
LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
LLM_BASE_URL=http://localhost:8000/v1  # vLLM or any OpenAI-compatible server

# Headless IDE fixer (legacy Docker-based — optional)
# IDE_FIXER_TOKEN=your_auth_token
# IDE_FIXER_IMAGE=ide-fixer

# Workspace
WORKSPACE_DIR=/tmp/sonarfix-workspaces

# Git (optional, for auto-push)
GIT_PUSH_REMOTE=origin
